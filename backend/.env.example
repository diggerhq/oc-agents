# Server
PORT=3000
SESSION_SECRET=your-session-secret-here

# GitHub OAuth (for user authentication)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# GitHub App (for granular repo access)
# Create a GitHub App at https://github.com/settings/apps
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_NAME=your-github-app-name
GITHUB_APP_CLIENT_ID=your-github-app-client-id
GITHUB_APP_PRIVATE_KEY=base64-encoded-private-key
GITHUB_APP_WEBHOOK_SECRET=your-webhook-secret

# Sandbox (OpenComputer)
OPENCOMPUTER_API_KEY=your-opencomputer-api-key

OPENCOMPUTER_SNAPSHOT_CLAUDE_CODE=claude-code-agent
OPENCOMPUTER_SNAPSHOT_AIDER=aider-agent
OPENCOMPUTER_SNAPSHOT_OPENCODE=opencode-agent

# Models
ANTHROPIC_API_KEY=your-anthropic-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Screenshot Service (for portal customizer)
SCREENSHOTONE_API_KEY=your-screenshotone-api-key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
WORKOS_CLIENT_ID=your-workos-client-id
WORKOS_API_KEY=your-workos-api-key

QDRANT_API_KEY=your-qdrant-api-key
QDRANT_CLUSTER=your-qdrant-cluster-url

AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-2
AWS_S3_BUCKET=your-s3-bucket-name
