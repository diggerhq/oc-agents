{
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of analysis"
        },
        "analysisVersion": {
          "type": "string",
          "pattern": "^v\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version of the analysis engine"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence score between 0 and 1"
        },
        "processingTimeMs": {
          "type": "integer",
          "minimum": 0,
          "description": "Time taken to process in milliseconds"
        }
      },
      "required": ["timestamp", "analysisVersion", "confidence"]
    },
    "analysis": {
      "type": "object",
      "properties": {
        "primaryFindings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^finding_[a-f0-9]{8}$",
                "description": "Unique finding identifier"
              },
              "category": {
                "type": "string",
                "enum": ["critical", "warning", "info", "optimization", "anomaly"]
              },
              "severity": {
                "type": "integer",
                "minimum": 1,
                "maximum": 10
              },
              "description": {
                "type": "string",
                "minLength": 10,
                "maxLength": 500
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["log", "metric", "pattern", "correlation", "statistical"]
                    },
                    "value": {
                      "oneOf": [
                        {"type": "string"},
                        {"type": "number"},
                        {"type": "boolean"},
                        {"type": "object"}
                      ]
                    },
                    "weight": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    }
                  },
                  "required": ["type", "value", "weight"]
                },
                "minItems": 1,
                "maxItems": 10
              },
              "recommendations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "action": {
                      "type": "string",
                      "enum": ["investigate", "fix", "monitor", "escalate", "ignore"]
                    },
                    "priority": {
                      "type": "string",
                      "enum": ["immediate", "high", "medium", "low", "deferred"]
                    },
                    "estimatedEffort": {
                      "type": "object",
                      "properties": {
                        "hours": {"type": "integer", "minimum": 0},
                        "complexity": {"type": "string", "enum": ["trivial", "simple", "moderate", "complex", "expert"]}
                      },
                      "required": ["hours", "complexity"]
                    },
                    "dependencies": {
                      "type": "array",
                      "items": {"type": "string"},
                      "description": "Other finding IDs that must be addressed first"
                    }
                  },
                  "required": ["action", "priority", "estimatedEffort"]
                }
              }
            },
            "required": ["id", "category", "severity", "description", "evidence", "recommendations"]
          },
          "minItems": 1,
          "maxItems": 20
        },
        "statisticalSummary": {
          "type": "object",
          "properties": {
            "dataPoints": {
              "type": "integer",
              "minimum": 0
            },
            "distributions": {
              "type": "object",
              "patternProperties": {
                "^[a-zA-Z_][a-zA-Z0-9_]*$": {
                  "type": "object",
                  "properties": {
                    "mean": {"type": "number"},
                    "median": {"type": "number"},
                    "stdDev": {"type": "number"},
                    "percentiles": {
                      "type": "object",
                      "properties": {
                        "p25": {"type": "number"},
                        "p50": {"type": "number"},
                        "p75": {"type": "number"},
                        "p90": {"type": "number"},
                        "p95": {"type": "number"},
                        "p99": {"type": "number"}
                      },
                      "required": ["p25", "p50", "p75", "p90", "p95", "p99"]
                    }
                  },
                  "required": ["mean", "median", "stdDev", "percentiles"]
                }
              },
              "additionalProperties": false
            },
            "correlationMatrix": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {"type": "number", "minimum": -1, "maximum": 1}
              },
              "description": "Square matrix of correlation coefficients"
            }
          },
          "required": ["dataPoints", "distributions"]
        },
        "temporalPatterns": {
          "type": "object",
          "properties": {
            "trends": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "metric": {"type": "string"},
                  "direction": {"type": "string", "enum": ["increasing", "decreasing", "stable", "volatile", "cyclical"]},
                  "strength": {"type": "number", "minimum": 0, "maximum": 1},
                  "seasonality": {
                    "type": "object",
                    "properties": {
                      "detected": {"type": "boolean"},
                      "period": {"type": "string", "enum": ["hourly", "daily", "weekly", "monthly", "quarterly", "yearly"]},
                      "amplitude": {"type": "number", "minimum": 0}
                    },
                    "required": ["detected"]
                  }
                },
                "required": ["metric", "direction", "strength", "seasonality"]
              }
            },
            "anomalies": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "timestamp": {"type": "string", "format": "date-time"},
                  "metric": {"type": "string"},
                  "expectedValue": {"type": "number"},
                  "actualValue": {"type": "number"},
                  "deviationScore": {"type": "number", "minimum": 0},
                  "anomalyType": {"type": "string", "enum": ["spike", "dip", "shift", "outlier", "missing"]}
                },
                "required": ["timestamp", "metric", "expectedValue", "actualValue", "deviationScore", "anomalyType"]
              }
            }
          },
          "required": ["trends", "anomalies"]
        }
      },
      "required": ["primaryFindings", "statisticalSummary", "temporalPatterns"]
    },
    "actionPlan": {
      "type": "object",
      "properties": {
        "immediate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "task": {"type": "string"},
              "assignee": {"type": "string", "enum": ["human", "automated", "hybrid"]},
              "deadline": {"type": "string", "format": "date-time"},
              "prerequisites": {"type": "array", "items": {"type": "string"}},
              "successCriteria": {"type": "array", "items": {"type": "string"}}
            },
            "required": ["task", "assignee", "deadline", "successCriteria"]
          }
        },
        "shortTerm": {
          "type": "array",
          "items": {
            "$ref": "#/properties/actionPlan/properties/immediate/items"
          }
        },
        "longTerm": {
          "type": "array",
          "items": {
            "$ref": "#/properties/actionPlan/properties/immediate/items"
          }
        },
        "riskAssessment": {
          "type": "object",
          "properties": {
            "overallRisk": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
            "riskFactors": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "factor": {"type": "string"},
                  "probability": {"type": "number", "minimum": 0, "maximum": 1},
                  "impact": {"type": "string", "enum": ["negligible", "minor", "moderate", "major", "catastrophic"]},
                  "mitigation": {"type": "string"}
                },
                "required": ["factor", "probability", "impact", "mitigation"]
              }
            }
          },
          "required": ["overallRisk", "riskFactors"]
        }
      },
      "required": ["immediate", "shortTerm", "longTerm", "riskAssessment"]
    },
    "systemHealth": {
      "type": "object",
      "properties": {
        "overallScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Overall system health score out of 100"
        },
        "dimensions": {
          "type": "object",
          "properties": {
            "performance": {"type": "number", "minimum": 0, "maximum": 100},
            "reliability": {"type": "number", "minimum": 0, "maximum": 100},
            "security": {"type": "number", "minimum": 0, "maximum": 100},
            "maintainability": {"type": "number", "minimum": 0, "maximum": 100},
            "scalability": {"type": "number", "minimum": 0, "maximum": 100}
          },
          "required": ["performance", "reliability", "security", "maintainability", "scalability"]
        },
        "trajectory": {
          "type": "string",
          "enum": ["improving", "stable", "degrading", "critical", "unknown"]
        }
      },
      "required": ["overallScore", "dimensions", "trajectory"]
    }
  },
  "required": ["meta", "analysis", "actionPlan", "systemHealth"],
  "additionalProperties": false
}